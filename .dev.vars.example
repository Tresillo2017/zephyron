# Zephyron — Environment Variables
# Copy this file to .dev.vars and fill in the values
# See wrangler.jsonc for Cloudflare bindings (DB, R2, AI, etc.)

# Better Auth — Required
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# Invidious Instance — Required for video metadata and audio streaming
# See https://docs.invidious.io/instances/ for public instances
INVIDIOUS_BASE_URL=https://invidious.tomasps.com

# YouTube Data API v3 — DEPRECATED (replaced by Invidious)
# Kept as optional fallback. Remove in a future version.
# YOUTUBE_API_KEY=

# Last.fm API — Required for artist/track enrichment
LASTFM_API_KEY=

# GitHub Personal Access Token — Required for "Request a Set" feature
# Needs: repo scope (or fine-grained with issues write permission)
GITHUB_TOKEN=

# Cloudflare Turnstile — Required for "Request a Set" form protection
# Get keys at: https://dash.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=

# Discord Bot Integration — Optional (for auto-posting new sets to Discord)
# Webhook URL from your deployed Discord bot (e.g., https://zephyron-bot.your-account.workers.dev/webhooks/zephyron)
# Secret should match ZEPHYRON_WEBHOOK_SECRET in the bot's .dev.vars
DISCORD_BOT_WEBHOOK_URL=
DISCORD_WEBHOOK_SECRET=
